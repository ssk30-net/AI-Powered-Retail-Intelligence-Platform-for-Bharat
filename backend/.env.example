# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=AI Market Pulse

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database
DATABASE_URL=postgresql://admin:password@localhost:5432/aimarketpulse

# JWT
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_RAW_DATA=ai-market-pulse-raw-data
S3_BUCKET_PROCESSED_DATA=ai-market-pulse-processed-data

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

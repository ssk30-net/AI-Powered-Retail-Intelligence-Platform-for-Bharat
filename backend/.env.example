# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=AI Market Pulse

# CORS (for local frontend)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database - choose one:
# Local PostgreSQL:
DATABASE_URL=postgresql://admin:password@localhost:5432/aimarketpulse
# AWS RDS (uncomment and set password if using; see LOCAL_RDS_SETUP.md):
# DATABASE_URL=postgresql://postgres:ai-market-pulse@database-1.cjqose8cc9yh.eu-north-1.rds.amazonaws.com:5432/aimarketpulse

# JWT
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_RAW_DATA=ai-market-pulse-raw-data
S3_BUCKET_PROCESSED_DATA=ai-market-pulse-processed-data

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI/ML Services (Optional - features work without these)
# OpenAI GPT for AI Copilot (get key from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude - Alternative LLM (get key from: https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Environment
ENVIRONMENT=development

{
  "family": "aimarketpulse-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::152641673729:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "152641673729.dkr.ecr.eu-north-1.amazonaws.com/aimarketpulse-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DATABASE_URL",
          "value": "postgresql://postgres:ai-market-pulse@database-1.cjqose8cc9yh.eu-north-1.rds.amazonaws.com:5432/aimarketpulse"
        },
        {
          "name": "SECRET_KEY",
          "value": "bH7@xL2!vZ9#pQ6$rT4^mW8&sD1*kA0yN5!cF3"
        },
        {
          "name": "API_V1_STR",
          "value": "/api/v1"
        },
        {
          "name": "PROJECT_NAME",
          "value": "AI Market Pulse"
        },
        {
          "name": "CORS_ORIGINS",
          "value": "*"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-north-1"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "value": "AKIASHCRHDIARDSLHROT"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "value": "dTRALrZYYLO60enreoyk2yfdwDbTL9p0OsxqY8bO"
        },
        {
          "name": "ENVIRONMENT",
          "value": "production"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aimarketpulse-backend",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}

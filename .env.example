# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# API Configuration
API_GATEWAY_URL=https://api.aimarketpulse.com
WEBSOCKET_URL=wss://api.aimarketpulse.com/realtime
GRAPHQL_URL=https://api.aimarketpulse.com/graphql

# Authentication
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=your-client-id
COGNITO_REGION=ap-south-1
JWT_SECRET=your-jwt-secret-key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aimarketpulse
RDS_ENDPOINT=your-rds-endpoint.ap-south-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=aimarketpulse
RDS_USERNAME=admin
RDS_PASSWORD=your-password

# DynamoDB
DYNAMODB_PRICES_TABLE=ai-market-pulse-prices
DYNAMODB_USERS_TABLE=ai-market-pulse-users
DYNAMODB_SUBSCRIPTIONS_TABLE=ai-market-pulse-subscriptions

# S3
S3_BUCKET_RAW_DATA=ai-market-pulse-raw-data
S3_BUCKET_PROCESSED_DATA=ai-market-pulse-processed-data
S3_BUCKET_ML_MODELS=ai-market-pulse-ml-models
S3_BUCKET_REPORTS=ai-market-pulse-reports

# SageMaker
SAGEMAKER_ENDPOINT_FORECASTING=forecasting-endpoint
SAGEMAKER_ROLE_ARN=arn:aws:iam::account-id:role/SageMakerRole

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-v2
BEDROCK_REGION=us-east-1

# Redis (ElastiCache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# External APIs
NEWS_API_KEY=your-newsapi-key
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Payment Gateways
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Email Service
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@aimarketpulse.com

# Monitoring
SENTRY_DSN=your-sentry-dsn
CLOUDWATCH_LOG_GROUP=/aws/lambda/ai-market-pulse

# Feature Flags
ENABLE_FORECASTING=true
ENABLE_SENTIMENT_ANALYSIS=false
ENABLE_LLM_INSIGHTS=false
ENABLE_REAL_TIME_UPDATES=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Environment
NODE_ENV=development
PYTHON_ENV=development
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Scraping
USER_AGENT=Mozilla/5.0 (compatible; AIMarketPulse/1.0)
SCRAPING_DELAY_MS=1000
MAX_CONCURRENT_REQUESTS=5
